SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
INGEST_TOKEN=

# 32-byte key (base64) for encrypting device claim secrets at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CLAIM_SECRET_ENC_KEY=

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# OTA firmware updates. ADMIN_USER_IDS is a comma-separated allowlist of Clerk
# user ids permitted to manage firmware releases at /dashboard/firmware.
# OTA_BASE_URL is the public origin the device reaches (must be the pinned-cert
# domain); used to build the firmware download URL sent in ingest offers.
ADMIN_USER_IDS=
OTA_BASE_URL=https://iot.serpis.id

# Tencent COS (private bucket) that stores firmware .bin artifacts.
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=

# Optional: override default Clerk redirect paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
