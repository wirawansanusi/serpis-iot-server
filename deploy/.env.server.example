# Copy to /opt/serpis-iot-server/.env on the VPS and fill in. NEVER commit the real file.
# These are RUNTIME secrets read by the server (not build args).

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
INGEST_TOKEN=
# Optional: previous token kept temporarily during fleet OTA rotation.
INGEST_TOKEN_LEGACY=
CLAIM_SECRET_ENC_KEY=
CLERK_SECRET_KEY=

# OTA firmware updates.
ADMIN_USER_IDS=
OTA_BASE_URL=https://iot.serpis.id
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=

# The publishable key is baked into the client bundle at build time (CI build-arg),
# so it isn't required here. Included only if something reads it at runtime:
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
